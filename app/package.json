{
  "name": "blue-shark-whatsapp-sender",
  "version": "1.1.0",
  "private": true,
  "description": "Portable local Blue Shark service-order sender",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <25"
