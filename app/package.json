  },
  "dependencies": {
    "archiver": "7.0.1",
    "express": "5.1.0",
    "html2pdf.js": "0.14.0",
    "multer": "2.2.0",
    "qrcode": "1.5.4",
    "unzipper": "0.12.3",
    "whatsapp-web.js": "1.34.7"
  }
}
